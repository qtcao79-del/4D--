<!-- 历史记录页 -->
<view class="page">

  <view class="header">
    <text class="header-title">测评历史</text>
    <text class="header-clear" bindtap="clearAll" wx:if="{{!isEmpty}}">清除全部</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{isEmpty}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">还没有测评记录</text>
    <text class="empty-sub">去测评页开始你的 4D 之旅吧</text>
  </view>

  <!-- 列表 -->
  <view class="list" wx:else>
    <view
      wx:for="{{list}}"
      wx:key="reportId"
      class="list-item"
      data-item="{{item}}"
      bindtap="viewDetail"
    >
      <view class="item-dot" style="background: {{item.typeColor}}"></view>
      <view class="item-info">
        <text class="item-type">{{item.typeName}}</text>
        <text class="item-date">{{item.date}}</text>
      </view>
      <text class="item-arrow">→</text>
    </view>
  </view>

</view>
