/* 注册页样式 */

.page {
  min-height: 100vh;
  background: #F5F5F7;
}

/* Hero */
.hero {
  padding: 60px 32px 40px;
  text-align: center;
}

.brand-badge {
  display: inline-block;
  background: linear-gradient(135deg, #1D1D1F 0%, #3A3A3C 100%);
  color: #FFFFFF;
  font-size: 13px;
  font-weight: 600;
  padding: 6px 18px;
  border-radius: 20px;
  margin-bottom: 24px;
  letter-spacing: 1px;
}

.hero-title {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 10px;
  line-height: 1.3;
}

.hero-desc {
  display: block;
  font-size: 14px;
  color: #86868B;
  line-height: 1.6;
}

/* 表单 */
.form-section {
  padding: 0 24px 40px;
}

.form-card {
  background: #FFFFFF;
  border-radius: 20px;
  padding: 28px 24px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.06);
}

.form-hint {
  display: block;
  font-size: 13px;
  color: #86868B;
  margin-bottom: 24px;
  text-align: center;
}

/* 输入组 */
.input-group {
  margin-bottom: 20px;
}

.input-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 8px;
}

.required {
  color: #FF3B30;
}

.optional {
  color: #C7C7CC;
  font-weight: 400;
  font-size: 12px;
}

.input-field {
  width: 100%;
  height: 48px;
  background: #F5F5F7;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 15px;
  color: #1D1D1F;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #C7C7CC;
}

/* 错误 */
.error-msg {
  background: #FFF2F0;
  border: 1px solid #FFCCC7;
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 16px;
}

.error-msg text {
  color: #FF3B30;
  font-size: 13px;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, #1D1D1F 0%, #3A3A3C 100%);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border-radius: 14px;
  margin-top: 8px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

/* 跳过 */
.skip-wrap {
  text-align: center;
  margin-top: 20px;
}

.skip-link {
  font-size: 14px;
  color: #86868B;
}
