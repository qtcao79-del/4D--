/* 首页样式 */

.page {
  min-height: 100vh;
  background: linear-gradient(135deg,
    rgba(74, 222, 128, 0.08),
    rgba(250, 204, 21, 0.08),
    rgba(59, 130, 246, 0.08),
    rgba(249, 115, 22, 0.08)
  );
}

/* ===== Hero ===== */
.hero {
  padding: 0 24px;
  text-align: center;
  padding-bottom: 40px;
}

.brand-badge {
  display: inline-flex;
  padding: 6px 16px;
  border-radius: 20px;
  background: #1D1D1F;
  margin-bottom: 32px;
}

.brand-badge text {
  color: #FFFFFF;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4px;
}

.hero-title-wrap {
  margin-bottom: 16px;
}

.hero-title {
  display: block;
  font-size: 40px;
  font-weight: 700;
  color: #1D1D1F;
  line-height: 1.1;
  letter-spacing: -1px;
}

.hero-subtitle {
  display: block;
  margin-top: 4px;
  font-size: 32px;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: -0.5px;
}

.hero-desc {
  display: block;
  font-size: 15px;
  color: #86868B;
  max-width: 320px;
  margin: 0 auto 32px;
  line-height: 1.6;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #1D1D1F;
  color: #FFFFFF;
  border: none;
  border-radius: 14px;
  padding: 14px 28px;
  font-size: 16px;
  font-weight: 600;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.cta-btn:active {
  transform: scale(0.97);
}

.cta-arrow {
  display: inline-block;
  transition: transform 0.2s;
}

/* ===== 四色矩阵预览 ===== */
.matrix-section {
  padding: 0 24px 40px;
}

.matrix-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  max-width: 400px;
  margin: 0 auto;
}

.matrix-card {
  position: relative;
  border-radius: 24px;
  padding: 16px;
  overflow: hidden;
  transition: all 0.4s;
  height: calc((100vw - 104px) / 2);
  max-height: 175px;
}

.matrix-card:active {
  transform: scale(1.04) translateY(-2px);
}

.matrix-card-glow {
  position: absolute;
  top: -30px;
  right: -30px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, transparent 70%);
  opacity: 0.4;
  filter: blur(16px);
}

.matrix-card-shadow {
  position: absolute;
  bottom: -40px;
  left: -20px;
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,0,0,0.9) 0%, transparent 70%);
  opacity: 0.25;
  filter: blur(16px);
}

.matrix-card-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #FFFFFF;
}

.matrix-jung {
  font-size: 10px;
  font-weight: 500;
  opacity: 0.9;
  line-height: 1.3;
}

.matrix-name-wrap {
  display: flex;
  align-items: baseline;
  gap: 2px;
  filter: drop-shadow(0 1px 2px rgba(0,0,0,0.2));
}

.matrix-name {
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

.matrix-type {
  font-size: 14px;
  font-weight: 600;
  opacity: 0.95;
}

.matrix-subtitle {
  font-size: 10px;
  font-weight: 500;
  opacity: 0.85;
  letter-spacing: 1px;
}

.matrix-tagline {
  display: block;
  text-align: center;
  margin-top: 24px;
  font-size: 15px;
  color: rgba(29,29,31,0.8);
  font-style: italic;
}

/* ===== 关注我们 ===== */
.follow-section {
  padding: 30px 24px;
  text-align: center;
  border-top: 1px solid #E5E5EA;
}

.follow-title {
  display: block;
  font-size: 17px;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 20px;
}

.qr-row {
  display: flex;
  justify-content: center;
  gap: 40px;
  margin-bottom: 16px;
}

.qr-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.qr-img {
  width: 120px;
  height: 120px;
  border-radius: 12px;
  border: 1px solid #E5E5EA;
  background: #F5F5F7;
}

.qr-label {
  font-size: 13px;
  color: #86868B;
  font-weight: 500;
}

.follow-hint {
  display: block;
  font-size: 12px;
  color: #C7C7CC;
  margin-top: 4px;
}

/* ===== 版权 ===== */
.footer {
  text-align: center;
  padding: 10px 24px 40px;
}

.footer text {
  display: block;
  font-size: 12px;
  color: #C7C7CC;
}

.footer-desc {
  margin-top: 2px;
}
