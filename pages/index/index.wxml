<!-- 首页 —— 飞昂叩启教练学院 · 4D 领导力系统 -->
<view class="page">

  <!-- Hero 区域 -->
  <view class="hero" style="padding-top: {{statusBarHeight + 40}}px;">
    <view class="brand-badge">
      <text>{{brand.name}}</text>
    </view>

    <view class="hero-title-wrap">
      <text class="hero-title">看见你的</text>
      <text class="hero-subtitle">
        <text style="color: var(--type-green)">天生</text>
        <text style="color: var(--type-yellow)">底层</text>
        <text style="color: var(--type-blue)">能量</text>
        <text style="color: var(--type-orange)">结构</text>
      </text>
    </view>

    <text class="hero-desc">{{brand.description}}</text>

    <button class="cta-btn" bindtap="startQuiz">
      <text>开启天生特质测评</text>
      <text class="cta-arrow">→</text>
    </button>
  </view>

  <!-- 四色矩阵预览 -->
  <view class="matrix-section">
    <view class="matrix-grid">
      <view wx:for="{{colors}}" wx:key="key"
        class="matrix-card"
        style="background: linear-gradient(140deg, {{item.color}} 0%, {{item.color}}dd 100%); box-shadow: 0 12px 30px -8px {{item.color}}88, inset 0 1px 0 rgba(255,255,255,0.25);"
      >
        <view class="matrix-card-glow"></view>
        <view class="matrix-card-shadow"></view>
        <view class="matrix-card-content">
          <text class="matrix-jung">{{item.jungCn}}</text>
          <view class="matrix-name-wrap">
            <text class="matrix-name">{{item.name}}</text>
            <text class="matrix-type"> · {{item.typeName}}</text>
          </view>
          <text class="matrix-subtitle">{{item.subtitle}}</text>
        </view>
      </view>
    </view>
    <text class="matrix-tagline">{{brand.tagline}}</text>
  </view>

  <!-- 关注我们 -->
  <view class="follow-section">
    <text class="follow-title">关注飞昂叩启</text>
    <view class="qr-row">
      <view class="qr-item">
        <image class="qr-img" src="/images/official-qr.png" mode="aspectFit"></image>
        <text class="qr-label">微信公众号</text>
      </view>
      <view class="qr-item">
        <image class="qr-img" src="/images/video-qr.png" mode="aspectFit"></image>
        <text class="qr-label">视频号</text>
      </view>
    </view>
    <text class="follow-hint">扫码关注，获取更多 4D 领导力内容</text>
  </view>

  <!-- 版权 -->
  <view class="footer">
    <text>{{brand.name}}</text>
    <text class="footer-desc">基于查理·佩勒林博士 NASA 4D 系统</text>
  </view>

</view>
